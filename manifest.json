{
  "manifest_version": 3,
  "name": "Voice Rewriter",
  "version": "0.2.0",
  "description": "Right-click any selected text to rewrite it in your own voice. Streaming preview via Vercel AI Gateway or OpenRouter.",
  "permissions": ["contextMenus", "storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Voice Rewriter — open settings"
  },
  "commands": {
    "rw-refine": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Refine the selected text"
    }
  }
}
